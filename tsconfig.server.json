{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "strict": false,
    "outDir": "dist/server"
  },
  "include": [
    "server/**/*.ts",
    "api/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src"
  ]
}
